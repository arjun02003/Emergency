# Example backend environment variables (do NOT store real secrets here)
# Copy this file to `backend/.env` and fill real values locally before running the backend.

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/suraksha_dev

# JWT secret for signing tokens
JWT_SECRET=your_jwt_secret_here

# Server port
PORT=5000

# Mapbox token (if used by backend)
MAPBOX_TOKEN=your_mapbox_token_here

# Seed defaults (optional)
SEED_ADMIN_EMAIL=admin@suraksha.com
SEED_ADMIN_PASSWORD=Admin@123
SEED_HOSPITAL_USER_EMAIL=hospital1@suraksha.com
SEED_HOSPITAL_PASSWORD=Hospital@123
